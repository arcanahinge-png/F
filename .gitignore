
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday My Love 💖</title>

<style>
body {
    margin: 0;
    padding: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #1a0026, #330033, #660066);
    color: white;
    overflow: hidden;
}

/* Center Content */
.container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
}

/* Main Text */
h1 {
    font-size: 50px;
    color: #ff66cc;
    animation: glow 2s infinite alternate;
}

p {
    font-size: 20px;
    max-width: 600px;
    margin: auto;
    line-height: 1.6;
}

/* Glow Animation */
@keyframes glow {
    from { text-shadow: 0 0 10px #ff66cc; }
    to { text-shadow: 0 0 25px #ff99dd, 0 0 40px #ff33aa; }
}

/* Floating Hearts */
.heart {
    position: absolute;
    width: 20px;
    height: 20px;
    background: pink;
    transform: rotate(45deg);
    animation: float 6s linear infinite;
}

.heart::before,
.heart::after {
    content: '';
    width: 20px;
    height: 20px;
    background: pink;
    border-radius: 50%;
    position: absolute;
}

.heart::before { top: -10px; left: 0; }
.heart::after { left: -10px; top: 0; }

@keyframes float {
    from { transform: translateY(100vh) rotate(45deg); opacity: 1; }
    to { transform: translateY(-10vh) rotate(45deg); opacity: 0; }
}

/* Button */
button {
    margin-top: 20px;
    padding: 12px 25px;
    border: none;
    background: #ff3399;
    color: white;
    font-size: 18px;
    border-radius: 25px;
    cursor: pointer;
    transition: 0.3s;
}

button:hover {
    background: #ff66cc;
    transform: scale(1.1);
}
</style>

</head>

<body>

<div class="container">
    <h1>Happy Birthday My Love 💖</h1>
    <p>
        You are the most beautiful part of my life.  
        Every moment with you feels like a dream come true.  
        I wish you endless happiness, love, and success.  
        I love you forever 💕
    </p>

    <button onclick="playMusic()">Click for Surprise 🎁</button>
</div>

<!-- Music -->
<audio id="music" loop>
    <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
</audio>

<script>
// Floating Hearts Generator
function createHeart() {
    const heart = document.createElement("div");
    heart.classList.add("heart");

    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = (Math.random() * 3 + 3) + "s";

    document.body.appendChild(heart);

    setTimeout(() => {
        heart.remove();
    }, 6000);
}

setInterval(createHeart, 300);

// Play Music
function playMusic() {
    document.getElementById("music").play();
    alert("I love you ❤️");
}
</script>

</body>
</html>
